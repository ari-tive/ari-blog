# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key

# GitHub Image Hosting
# Personal Access Token with repo scope — used server-side only to commit images
GITHUB_PAT=github_pat_xxxxx
# GitHub repo where images are stored (must already exist)
GITHUB_IMAGE_REPO_OWNER=your_github_username
GITHUB_IMAGE_REPO_NAME=your_image_repo_name
